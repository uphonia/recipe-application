# .gitignore

# Ignore environment variables and secrets
.env
.env.local

# Ignore build folder
/dist
/build

# Ignore logs
*.log

# frontend
frontend/next-env.d.ts
frontend/node_modules/

*-lock.json

.next
*storybook.log
storybook-static

.DS_Store
**/.DS_Store

*/.tsbuildinfo

backend/venv/
backend/__pycache__/
backend/*.pyc
backend/media/
backend/.env
backend/db.sqlite3
backend/backend/*.pyc

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class